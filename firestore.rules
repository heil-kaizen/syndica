rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: profiles
    // Document ID: auto-generated
    // Fields:
    //   - userId: string
    //   - name: string
    //   - createdAt: string (ISO 8601)
    //
    // Subcollection: profiles/{profileId}/tokens
    // Document ID: token address (mint)
    // Fields:
    //   - mcap: number
    //   - price: number
    //   - timestamp: string (ISO 8601)
    //   - symbol: string
    //   - name: string
    //   - holders: list of objects { wallet: string, balance: number, percentage: number, rank: number }
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredProfileFields() {
      return request.resource.data.keys().hasAll(['userId', 'name', 'createdAt']);
    }

    function isValidProfile() {
      return hasRequiredProfileFields() &&
             request.resource.data.userId is string &&
             request.resource.data.name is string &&
             request.resource.data.createdAt is string;
    }

    function hasRequiredTokenFields() {
      return request.resource.data.keys().hasAll(['mcap', 'price', 'timestamp', 'holders']);
    }

    function isValidTokenSnapshot() {
      return hasRequiredTokenFields() &&
             request.resource.data.mcap is number &&
             request.resource.data.price is number &&
             request.resource.data.timestamp is string &&
             request.resource.data.holders is list &&
             request.resource.data.holders.size() <= 100;
    }

    match /profiles/{profileId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidProfile() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidProfile() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      match /tokens/{tokenId} {
        // We must check the parent profile's userId to ensure only the owner can read/write their tokens
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/profiles/$(profileId)).data.userId == request.auth.uid;
        allow create: if isAuthenticated() && isValidTokenSnapshot() && get(/databases/$(database)/documents/profiles/$(profileId)).data.userId == request.auth.uid;
        allow update: if isAuthenticated() && isValidTokenSnapshot() && get(/databases/$(database)/documents/profiles/$(profileId)).data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && get(/databases/$(database)/documents/profiles/$(profileId)).data.userId == request.auth.uid;
      }
    }
    
    // Legacy rules (keep for now to avoid breaking existing data)
    match /tokens/{tokenId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTokenSnapshot();
      allow update: if isAuthenticated() && isValidTokenSnapshot();
    }

    match /wallet_index/{walletId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }
  }
}
